import React, { useState, useEffect } from 'react';
import Layout from '../components/Layout';
import { useAuth } from '../contexts/AuthContext';
import { researchOfficeAPI } from '../services/api';

const ResearchOfficeProfile = () => {
  const { user } = useAuth();
  const [dashboardData, setDashboardData] = useState(null);
  const [pendingRequests, setPendingRequests] = useState(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState('');
  const [activeTab, setActiveTab] = useState('overview');
  const [searchQuery, setSearchQuery] = useState('');
  const [filterStatus, setFilterStatus] = useState('all');
  const [filterProgram, setFilterProgram] = useState('all');

  useEffect(() => {
    loadData();
  }, []);

  const loadData = async () => {
    try {
      setLoading(true);
      const [dashboardRes, pendingRes] = await Promise.all([
        researchOfficeAPI.getDashboard(),
        researchOfficeAPI.getPendingRequests()
      ]);
      setDashboardData(dashboardRes.data);
      setPendingRequests(pendingRes.data);
    } catch (error) {
      console.error('Error loading data:', error);
      setError(error.response?.data?.error || 'Failed to load data');
    } finally {
      setLoading(false);
    }
  };

  const getStatusBadge = (status) => {
    const statusColors = {
      'active': 'bg-green-100 text-green-800',
      'on_leave': 'bg-yellow-100 text-yellow-800',
      'graduated': 'bg-blue-100 text-blue-800',
      'withdrawn': 'bg-red-100 text-red-800'
    };
    return statusColors[status] || 'bg-gray-100 text-gray-800';
  };

  const filteredStudents = dashboardData?.scholars?.filter(student => {
    const matchesSearch = !searchQuery ||
      student.user?.name.toLowerCase().includes(searchQuery.toLowerCase()) ||
      student.enrollment_number.toLowerCase().includes(searchQuery.toLowerCase());

    const matchesStatus = filterStatus === 'all' || student.status === filterStatus;
    const matchesProgram = filterProgram === 'all' || student.program === filterProgram;

    return matchesSearch && matchesStatus && matchesProgram;
  }) || [];

  const filteredFaculty = dashboardData?.faculty?.filter(fac => {
    return !searchQuery || fac.user?.name.toLowerCase().includes(searchQuery.toLowerCase());
  }) || [];

  if (loading) {
    return (
      <Layout>
        <div className="flex items-center justify-center h-64">
          <div className="spinner"></div>
        </div>
      </Layout>
    );
  }

  if (error) {
    return (
      <Layout>
        <div className="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
          {error}
        </div>
      </Layout>
    );
  }

  if (!dashboardData) {
    return (
      <Layout>
        <div className="text-center py-12">
          <p className="text-xl text-gray-500">No data available</p>
        </div>
      </Layout>
    );
  }

  return (
    <Layout>
      <div className="mb-6">
        <h1 className="text-3xl font-bold text-gray-800">Research Office Dashboard</h1>
        <p className="text-gray-600 mt-2">Comprehensive overview of all research activities</p>
      </div>

      {/* Main Statistics Grid */}
      <div className="grid grid-cols-1 md:grid-cols-5 gap-6 mb-6">
        <div className="card bg-indigo-50 border-l-4 border-indigo-500">
          <p className="text-sm text-indigo-600 font-medium">Total Schools</p>
          <p className="text-3xl font-bold text-indigo-900 mt-2">
            {dashboardData.statistics?.schools?.total || 0}
          </p>
        </div>
        <div className="card bg-blue-50 border-l-4 border-blue-500">
          <p className="text-sm text-blue-600 font-medium">Total Students</p>
          <p className="text-3xl font-bold text-blue-900 mt-2">
            {dashboardData.statistics?.students?.total || 0}
          </p>
        </div>
        <div className="card bg-green-50 border-l-4 border-green-500">
          <p className="text-sm text-green-600 font-medium">Active Students</p>
          <p className="text-3xl font-bold text-green-900 mt-2">
            {dashboardData.statistics?.students?.active || 0}
          </p>
        </div>
        <div className="card bg-purple-50 border-l-4 border-purple-500">
          <p className="text-sm text-purple-600 font-medium">Total Faculty</p>
          <p className="text-3xl font-bold text-purple-900 mt-2">
            {dashboardData.statistics?.faculty?.total || 0}
          </p>
        </div>
        <div className="card bg-red-50 border-l-4 border-red-500">
          <p className="text-sm text-red-600 font-medium">Pending Items</p>
          <p className="text-3xl font-bold text-red-900 mt-2">
            {dashboardData.statistics?.pending_items?.total || 0}
          </p>
        </div>
      </div>

      {/* Secondary Statistics */}
      <div className="grid grid-cols-1 md:grid-cols-4 gap-6 mb-6">
        <div className="card bg-gradient-to-br from-purple-50 to-pink-50">
          <p className="text-sm text-purple-600 font-medium mb-2">Program Distribution</p>
          <div className="space-y-2">
            <div className="flex justify-between">
              <span className="text-sm text-gray-600">PhD</span>
              <span className="font-bold text-purple-700">{dashboardData.statistics?.students?.phd || 0}</span>
            </div>
            <div className="flex justify-between">
              <span className="text-sm text-gray-600">M.Sc.</span>
              <span className="font-bold text-pink-700">{dashboardData.statistics?.students?.msc || 0}</span>
            </div>
          </div>
        </div>

        <div className="card bg-gradient-to-br from-green-50 to-teal-50">
          <p className="text-sm text-green-600 font-medium mb-2">Student Status</p>
          <div className="space-y-2">
            <div className="flex justify-between">
              <span className="text-sm text-gray-600">On Leave</span>
              <span className="font-bold text-yellow-700">{dashboardData.statistics?.students?.on_leave || 0}</span>
            </div>
            <div className="flex justify-between">
              <span className="text-sm text-gray-600">Graduated</span>
              <span className="font-bold text-blue-700">{dashboardData.statistics?.students?.graduated || 0}</span>
            </div>
          </div>
        </div>

        <div className="card bg-gradient-to-br from-orange-50 to-red-50">
          <p className="text-sm text-orange-600 font-medium mb-2">Pending Reviews</p>
          <div className="space-y-2">
            <div className="flex justify-between">
              <span className="text-sm text-gray-600">Synopsis</span>
              <span className="font-bold text-orange-700">{dashboardData.statistics?.pending_items?.synopsis || 0}</span>
            </div>
            <div className="flex justify-between">
              <span className="text-sm text-gray-600">Reports</span>
              <span className="font-bold text-red-700">{dashboardData.statistics?.pending_items?.progress_reports || 0}</span>
            </div>
          </div>
        </div>

        <div className="card bg-gradient-to-br from-blue-50 to-indigo-50">
          <p className="text-sm text-blue-600 font-medium mb-2">Admission Mode</p>
          <div className="space-y-2">
            <div className="flex justify-between">
              <span className="text-sm text-gray-600">Regular</span>
              <span className="font-bold text-blue-700">{dashboardData.statistics?.students?.by_admission_mode?.regular || 0}</span>
            </div>
            <div className="flex justify-between">
              <span className="text-sm text-gray-600">Sponsored</span>
              <span className="font-bold text-indigo-700">{dashboardData.statistics?.students?.by_admission_mode?.sponsored || 0}</span>
            </div>
          </div>
        </div>
      </div>

      {/* Tabs */}
      <div className="card">
        <div className="border-b border-gray-200">
          <nav className="flex space-x-8">
            <button
              onClick={() => setActiveTab('overview')}
              className={`py-4 px-1 border-b-2 font-medium text-sm transition-colors ${
                activeTab === 'overview'
                  ? 'border-primary-500 text-primary-600'
                  : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'
              }`}
            >
              Overview
            </button>
            <button
              onClick={() => setActiveTab('schools')}
              className={`py-4 px-1 border-b-2 font-medium text-sm transition-colors ${
                activeTab === 'schools'
                  ? 'border-primary-500 text-primary-600'
                  : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'
              }`}
            >
              Schools ({dashboardData.schools?.length || 0})
            </button>
            <button
              onClick={() => setActiveTab('students')}
              className={`py-4 px-1 border-b-2 font-medium text-sm transition-colors ${
                activeTab === 'students'
                  ? 'border-primary-500 text-primary-600'
                  : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'
              }`}
            >
              Students ({dashboardData.scholars?.length || 0})
            </button>
            <button
              onClick={() => setActiveTab('faculty')}
              className={`py-4 px-1 border-b-2 font-medium text-sm transition-colors ${
                activeTab === 'faculty'
                  ? 'border-primary-500 text-primary-600'
                  : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'
              }`}
            >
              Faculty ({dashboardData.faculty?.length || 0})
            </button>
            <button
              onClick={() => setActiveTab('pending')}
              className={`py-4 px-1 border-b-2 font-medium text-sm transition-colors ${
                activeTab === 'pending'
                  ? 'border-primary-500 text-primary-600'
                  : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'
              }`}
            >
              Pending ({pendingRequests?.total_count || 0})
            </button>
          </nav>
        </div>

        {/* Tab Content */}
        <div className="mt-6">
          {/* Overview Tab */}
          {activeTab === 'overview' && (
            <div className="space-y-6">
              <div>
                <h3 className="text-lg font-semibold text-gray-800 mb-4">Quick Summary</h3>
                <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
                  <div className="bg-gradient-to-br from-blue-50 to-cyan-50 rounded-lg p-6">
                    <h4 className="font-semibold text-blue-800 mb-3">Students Overview</h4>
                    <div className="space-y-2 text-sm">
                      <div className="flex justify-between"><span>Total:</span><span className="font-bold">{dashboardData.statistics?.students?.total}</span></div>
                      <div className="flex justify-between"><span>Active:</span><span className="font-bold">{dashboardData.statistics?.students?.active}</span></div>
                      <div className="flex justify-between"><span>PhD:</span><span className="font-bold">{dashboardData.statistics?.students?.phd}</span></div>
                      <div className="flex justify-between"><span>M.Sc.:</span><span className="font-bold">{dashboardData.statistics?.students?.msc}</span></div>
                    </div>
                  </div>

                  <div className="bg-gradient-to-br from-purple-50 to-pink-50 rounded-lg p-6">
                    <h4 className="font-semibold text-purple-800 mb-3">Faculty Overview</h4>
                    <div className="space-y-2 text-sm">
                      <div className="flex justify-between"><span>Total:</span><span className="font-bold">{dashboardData.statistics?.faculty?.total}</span></div>
                      <div className="flex justify-between"><span>Accepting:</span><span className="font-bold">{dashboardData.statistics?.faculty?.accepting_students}</span></div>
                      <div className="flex justify-between"><span>Not Accepting:</span><span className="font-bold">{dashboardData.statistics?.faculty?.not_accepting}</span></div>
                    </div>
                  </div>

                  <div className="bg-gradient-to-br from-orange-50 to-red-50 rounded-lg p-6">
                    <h4 className="font-semibold text-orange-800 mb-3">Pending Reviews</h4>
                    <div className="space-y-2 text-sm">
                      <div className="flex justify-between"><span>Synopsis:</span><span className="font-bold">{dashboardData.statistics?.pending_items?.synopsis}</span></div>
                      <div className="flex justify-between"><span>Reports:</span><span className="font-bold">{dashboardData.statistics?.pending_items?.progress_reports}</span></div>
                      <div className="flex justify-between"><span>Thesis:</span><span className="font-bold">{dashboardData.statistics?.pending_items?.thesis}</span></div>
                      <div className="flex justify-between"><span>Travel:</span><span className="font-bold">{dashboardData.statistics?.pending_items?.travel_grants}</span></div>
                    </div>
                  </div>
                </div>
              </div>

              {/* Upcoming Events */}
              <div>
                <h3 className="text-lg font-semibold text-gray-800 mb-4">Upcoming Events</h3>
                <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div className="bg-blue-50 rounded-lg p-4">
                    <h4 className="font-semibold text-blue-800 mb-3">Upcoming Exams</h4>
                    {dashboardData.statistics?.upcoming?.exams?.length > 0 ? (
                      <div className="space-y-2">
                        {dashboardData.statistics.upcoming.exams.map((exam, idx) => (
                          <div key={idx} className="text-sm bg-white rounded p-2">
                            <div className="flex justify-between">
                              <span className="font-medium">{exam.exam_type}</span>
                              <span className="text-gray-500">{new Date(exam.scheduled_date).toLocaleDateString()}</span>
                            </div>
                            <div className="text-xs text-gray-600 mt-1">{exam.scholar}</div>
                          </div>
                        ))}
                      </div>
                    ) : (
                      <p className="text-sm text-gray-500">No upcoming exams</p>
                    )}
                  </div>

                  <div className="bg-purple-50 rounded-lg p-4">
                    <h4 className="font-semibold text-purple-800 mb-3">Upcoming Seminars</h4>
                    {dashboardData.statistics?.upcoming?.seminars?.length > 0 ? (
                      <div className="space-y-2">
                        {dashboardData.statistics.upcoming.seminars.map((seminar, idx) => (
                          <div key={idx} className="text-sm bg-white rounded p-2">
                            <div className="flex justify-between">
                              <span className="font-medium">{seminar.seminar_type}</span>
                              <span className="text-gray-500">{new Date(seminar.scheduled_date).toLocaleDateString()}</span>
                            </div>
                            <div className="text-xs text-gray-600 mt-1">{seminar.title}</div>
                          </div>
                        ))}
                      </div>
                    ) : (
                      <p className="text-sm text-gray-500">No upcoming seminars</p>
                    )}
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Schools Tab */}
          {activeTab === 'schools' && (
            <div className="space-y-4">
              {dashboardData.schools?.map((school) => (
                <div key={school.id} className="border border-gray-200 rounded-lg p-5 hover:shadow-md transition-shadow">
                  <div className="flex justify-between items-start">
                    <div>
                      <h4 className="text-lg font-semibold text-gray-800">{school.name}</h4>
                      <p className="text-sm text-gray-500">Code: {school.code}</p>
                    </div>
                    <div className="text-right">
                      <p className="text-sm text-gray-600">Chair: {school.chair?.name || 'Not assigned'}</p>
                    </div>
                  </div>
                  <div className="grid grid-cols-3 gap-4 mt-4">
                    <div className="bg-blue-50 rounded p-3">
                      <p className="text-xs text-blue-600 mb-1">Faculty</p>
                      <p className="text-2xl font-bold text-blue-800">{school.faculty_count}</p>
                    </div>
                    <div className="bg-green-50 rounded p-3">
                      <p className="text-xs text-green-600 mb-1">Students</p>
                      <p className="text-2xl font-bold text-green-800">{school.student_count}</p>
                    </div>
                    <div className="bg-purple-50 rounded p-3">
                      <p className="text-xs text-purple-600 mb-1">Active</p>
                      <p className="text-2xl font-bold text-purple-800">{school.active_students}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          )}

          {/* Students Tab */}
          {activeTab === 'students' && (
            <div>
              <div className="mb-6 flex flex-col md:flex-row gap-4">
                <input
                  type="text"
                  placeholder="Search students..."
                  value={searchQuery}
                  onChange={(e) => setSearchQuery(e.target.value)}
                  className="input-field flex-1"
                />
                <select
                  value={filterStatus}
                  onChange={(e) => setFilterStatus(e.target.value)}
                  className="input-field w-full md:w-48"
                >
                  <option value="all">All Status</option>
                  <option value="active">Active</option>
                  <option value="on_leave">On Leave</option>
                  <option value="graduated">Graduated</option>
                </select>
                <select
                  value={filterProgram}
                  onChange={(e) => setFilterProgram(e.target.value)}
                  className="input-field w-full md:w-48"
                >
                  <option value="all">All Programs</option>
                  <option value="PhD">PhD</option>
                  <option value="M.Sc. (Research)">M.Sc.</option>
                </select>
              </div>

              <div className="space-y-4">
                {filteredStudents.slice(0, 50).map((student) => (
                  <div key={student.id} className="border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow">
                    <div className="flex justify-between items-start mb-3">
                      <div>
                        <h4 className="font-semibold text-gray-800">{student.user?.name}</h4>
                        <p className="text-sm text-gray-500">{student.enrollment_number}</p>
                      </div>
                      <span className={`px-3 py-1 rounded-full text-xs font-medium ${getStatusBadge(student.status)}`}>
                        {student.status?.toUpperCase()}
                      </span>
                    </div>
                    <div className="grid grid-cols-2 md:grid-cols-4 gap-3 text-sm">
                      <div><span className="text-gray-500">Program:</span> <span className="font-medium">{student.program}</span></div>
                      <div><span className="text-gray-500">School:</span> <span className="font-medium">{student.school?.code || 'N/A'}</span></div>
                      <div><span className="text-gray-500">Supervisor:</span> <span className="font-medium">{student.supervisor?.name || 'Not assigned'}</span></div>
                      <div><span className="text-gray-500">Mode:</span> <span className="font-medium">{student.admission_mode || 'Regular'}</span></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* Faculty Tab */}
          {activeTab === 'faculty' && (
            <div>
              <div className="mb-6">
                <input
                  type="text"
                  placeholder="Search faculty..."
                  value={searchQuery}
                  onChange={(e) => setSearchQuery(e.target.value)}
                  className="input-field w-full md:w-96"
                />
              </div>

              <div className="space-y-4">
                {filteredFaculty.map((faculty) => (
                  <div key={faculty.id} className="border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow">
                    <div className="flex justify-between items-start mb-3">
                      <div>
                        <h4 className="font-semibold text-gray-800">{faculty.user?.name}</h4>
                        <p className="text-sm text-gray-500">{faculty.employee_id}</p>
                      </div>
                      <span className={`px-3 py-1 rounded-full text-xs font-medium ${
                        faculty.is_accepting_students ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'
                      }`}>
                        {faculty.is_accepting_students ? 'Accepting' : 'Not Accepting'}
                      </span>
                    </div>
                    <div className="grid grid-cols-2 md:grid-cols-4 gap-3 text-sm">
                      <div><span className="text-gray-500">Designation:</span> <span className="font-medium">{faculty.designation}</span></div>
                      <div><span className="text-gray-500">School:</span> <span className="font-medium">{faculty.school?.code || 'N/A'}</span></div>
                      <div><span className="text-gray-500">Students:</span> <span className="font-medium">{faculty.current_student_count}</span></div>
                      <div><span className="text-gray-500">Capacity:</span> <span className="font-medium">PhD: {faculty.max_phd_scholars}, MSc: {faculty.max_msc_scholars}</span></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* Pending Tab */}
          {activeTab === 'pending' && pendingRequests && (
            <div className="space-y-6">
              {pendingRequests.synopsis?.length > 0 && (
                <div>
                  <h3 className="font-semibold text-gray-800 mb-3">Pending Synopsis ({pendingRequests.synopsis.length})</h3>
                  <div className="space-y-2">
                    {pendingRequests.synopsis.map((item) => (
                      <div key={item.id} className="bg-blue-50 border border-blue-200 rounded p-3">
                        <div className="flex justify-between">
                          <div>
                            <p className="font-medium">{item.title}</p>
                            <p className="text-sm text-gray-600">{item.scholar?.name} ({item.scholar?.enrollment_number})</p>
                          </div>
                          <span className="text-xs text-gray-500">{new Date(item.submitted_date).toLocaleDateString()}</span>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {pendingRequests.progress_reports?.length > 0 && (
                <div>
                  <h3 className="font-semibold text-gray-800 mb-3">Pending Progress Reports ({pendingRequests.progress_reports.length})</h3>
                  <div className="space-y-2">
                    {pendingRequests.progress_reports.map((item) => (
                      <div key={item.id} className="bg-green-50 border border-green-200 rounded p-3">
                        <div className="flex justify-between">
                          <div>
                            <p className="font-medium">{item.report_period}</p>
                            <p className="text-sm text-gray-600">{item.scholar?.name} ({item.scholar?.enrollment_number})</p>
                          </div>
                          <span className="text-xs text-gray-500">{new Date(item.submitted_date).toLocaleDateString()}</span>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {pendingRequests.supervisor_changes?.length > 0 && (
                <div>
                  <h3 className="font-semibold text-gray-800 mb-3">Pending Supervisor Changes ({pendingRequests.supervisor_changes.length})</h3>
                  <div className="space-y-2">
                    {pendingRequests.supervisor_changes.map((item) => (
                      <div key={item.id} className="bg-purple-50 border border-purple-200 rounded p-3">
                        <div>
                          <p className="font-medium">{item.scholar?.name} ({item.scholar?.enrollment_number})</p>
                          <p className="text-sm text-gray-600">From: {item.current_supervisor} → To: {item.new_supervisor}</p>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {pendingRequests.total_count === 0 && (
                <div className="text-center py-12">
                  <p className="text-xl text-gray-500">No pending requests</p>
                </div>
              )}
            </div>
          )}
        </div>
      </div>
    </Layout>
  );
};

export default ResearchOfficeProfile;
